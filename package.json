{
  "name": "vietnamese-language-support",
  "version": "1.0.0",
  "description": "Vietnamese spelling/grammar correction, language mixing detection, native fluency for weak-Vietnamese models",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./tools/vn_fix": "./tools/vn_fix.json",
    "./tools/vn_check": "./tools/vn_check.json",
    "./tools/vn_native": "./tools/vn_native.json",
    "./tools/vn_idiom": "./tools/vn_idiom.json",
    "./tools/vn_region": "./tools/vn_region.json",
    "./hooks/post_model_output": "./hooks/post_model_output.js",
    "./health": "./health.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "vietnamese",
    "nlp",
    "language-model",
    "post-processing",
    "grammar",
    "spelling",
    "openclaw",
    "skill"
  ],
  "author": "Min",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/vietnamese-language-support"
  },
  "files": [
    "dist",
    "tools",
    "hooks",
    "health.js",
    "skill.json",
    "assets"
  ],
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "@types/node": "^20.12.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "openclaw": {
    "skill": "vietnamese-language-support",
    "version": "1.0.0",
    "entryPoint": "dist/index.js",
    "tools": [
      "vn_fix",
      "vn_check",
      "vn_native",
      "vn_idiom",
      "vn_region"
    ],
    "hooks": {
      "post_model_output": "hooks/post_model_output.js"
    },
    "healthCheck": "health.js",
    "configSchema": {
      "type": "object",
      "properties": {
        "dictPath": { "type": "string", "default": "assets" },
        "whitelist": { "type": "array", "items": { "type": "string" }, "default": [] },
        "enableMixingDetection": { "type": "boolean", "default": true },
        "formalLevel": { "type": "string", "enum": ["auto", "formal", "casual"], "default": "auto" },
        "stripMixing": { "type": "boolean", "default": true },
        "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"], "default": "info" }
      }
    }
  }
}